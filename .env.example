# Environment Variables — YWM Dashboard
# Salin file ini ke .env.local dan isi nilai yang sesuai
# Last updated: 2026-05-29

# ── Supabase (Database) ──
# Dapatkan dari: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── EmailJS (Contact Form) ──
# Dapatkan dari: https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── PWA Push Notifications (Optional) ──
# VAPID public key untuk push notifications
# Generate: https://web-push-codelab.glitch.me/
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
